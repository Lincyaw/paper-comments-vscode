{
  "name": "paper-comments",
  "displayName": "Paper Comments",
  "description": "Show paper review comments as VSCode diagnostics from .paper-comments.jsonl",
  "publisher": "lincyaw",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lincyaw/paper-comments-vscode"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "icon.png",
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "workspaceContains:.paper-comments.jsonl"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -watch"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
